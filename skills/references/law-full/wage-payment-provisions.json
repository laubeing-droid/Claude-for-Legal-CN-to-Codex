{ "_meta": { "law_name": "工资支付暂行规定", "short_name": "工资支付暂行规定", "version": "1994年", "effective_date": "1995-01-01", "total_articles": 21, "type": "部门规章", "source": "劳动部" }, "key_provisions": { "工资支付周期": "7", "加班工资": "13", "假期工资": "11", "停工工资": "12", "克扣拖欠": "15/18" }, "articles": { "13": {"text": "……（一）安排劳动者延长工作时间的，支付不低于工资的150%的工资报酬；（二）休息日安排劳动者工作又不能安排补休的，支付不低于工资的200%的工资报酬；（三）法定休假日安排劳动者工作的，支付不低于工资的300%的工资报酬。", "tags": ["加班费","高频"]} } }
