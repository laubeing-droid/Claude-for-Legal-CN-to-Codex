{ "_meta": { "law_name": "职工带薪年休假条例", "short_name": "带薪年休假条例", "version": "2008年", "effective_date": "2008-01-01", "total_articles": 10, "type": "行政法规" }, "key_provisions": { "年假天数": "3", "不计入年假": "4", "未休补偿300%": "5" }, "articles": { "3": {"text": "职工累计工作已满1年不满10年的，年休假5天；已满10年不满20年的，年休假10天；已满20年的，年休假15天……", "tags": ["天数"]}, "5": {"text": "……对职工应休未休的年休假天数，单位应当按照该职工日工资收入的300%支付年休假工资报酬。", "tags": ["未休补偿"]} } }
