{ "_meta": { "law_name": "中华人民共和国广告法", "short_name": "广告法", "version": "2021年修正", "effective_date": "2021-04-29", "total_articles": 75 }, "key_provisions": { "虚假广告": "28", "绝对化用语": "9", "未成年人保护": "38-40", "互联网广告": "44", "广告代言人": "38/56/62", "处罚": "55-58", "医疗广告": "16-17", "烟草广告": "22" }, "articles": { "9": {"text": "广告不得有下列情形：……（三）使用\"国家级\"、\"最高级\"、\"最佳\"等用语……", "tags": ["绝对化用语","高频"]}, "28": {"text": "广告以虚假或者引人误解的内容欺骗、误导消费者的，构成虚假广告……", "tags": ["虚假广告"]} } }
